# ============================================================
# JDC Chatbot — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no repositório
# ============================================================

# Telegram Bot Token (obtenha via @BotFather no Telegram)
TELEGRAM_TOKEN=seu_token_aqui

# Anthropic API Key (obtenha em console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Modelo Claude a utilizar (opcional)
CLAUDE_MODEL=claude-sonnet-4-6

# Tamanho do modelo Whisper para transcrição de voz (opcional)
# Opções: tiny (~75MB), base (~150MB), small (~500MB), medium (~1.5GB)
# Mais leve = mais rápido, menos preciso | Mais pesado = mais lento, mais preciso
WHISPER_MODEL=base

# Número máximo de mensagens de histórico por usuário (opcional)
MAX_HISTORY_MESSAGES=10

# Nível de log (opcional): DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
